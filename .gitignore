**/.DS_Store
.idea/
.vs/
.vscode/

# CMake build directories (all presets)
build/
build-*/
cmake-build-*/
prefix/

# CMake user files
.clangd
.cache/
CMakeLists.txt.user
CMakeUserPresets.json
compile_commands.json

# Doxygen generated output
docs/html/
docs/Doxyfile.configured

# Local secrets — never commit (config.json is committed; it must hold no
# credentials, only a secrets_path pointing at the gitignored secrets file)
secrets.json
config-demo.json
# Generated trade configs copy secrets from the base config — never commit
*.trade.json
pnl_state.json
*.pem
# API keys, private keys, and local demo configs — never commit
/api-keys/

# Runtime logs
logs/

# Scan output artifact
scan_results.json
docs/papers/*.pdf

# Session recordings (raw frames + financial fills)
capture/
